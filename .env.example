# MOSBot environment variables
# Copy to .env and fill in real values. Never commit .env.

# Twitch Developer App (Device Code Flow enabled)
# Register at https://dev.twitch.tv/console/apps
# DCF requires only the client_id (no secret).
TWITCH_CLIENT_ID=

# 32-byte base64 key used to encrypt tokens at rest (AES-256-GCM).
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# argon2id hash of the dashboard password.
# Generate with:
#   docker run --rm node:20-alpine sh -c "npm i -g argon2-cli >/dev/null && argon2-cli hash -p 'your-password'"
# Or run `node scripts/hash-password.mjs` from a local checkout.
DASHBOARD_PASSWORD_HASH=

# Optional runtime knobs
TZ=Europe/Berlin
NODE_ENV=production
LOG_LEVEL=info
