{
  "name": "@mosbot/bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.1",
    "@fastify/session": "^11.0.1",
    "@fastify/static": "^7.0.4",
    "@fastify/websocket": "^10.0.1",
    "@mosbot/shared": "workspace:*",
    "@twurple/api": "^7.2.0",
    "@twurple/auth": "^7.2.0",
    "@twurple/auth-tmi": "^7.2.0",
    "@twurple/chat": "^7.2.0",
    "argon2": "^0.41.1",
    "better-sqlite3": "^11.5.0",
    "drizzle-orm": "^0.36.4",
    "fastify": "^4.28.1",
    "js-yaml": "^4.1.0",
    "pino": "^9.5.0",
    "pino-roll": "^2.1.0",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.9.3",
    "@vitest/coverage-v8": "^2.1.5",
    "drizzle-kit": "^0.29.0",
    "msw": "^2.6.5",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
